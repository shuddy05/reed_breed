datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator db {
  provider = "go run github.com/steebchen/prisma-client-go"
}

model AuditRequest {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  industry    String
  subCategory String
  challenges  String
  techStack   String
  goal        String
  name        String
  email       String
  phone       String
  company     String
  status      String   @default("PENDING") // PENDING, REVIEWED, CONVERTED
  userId      String?
  user        User?    @relation(fields: [userId], references: [id])
}

model User {
  id           String         @id @default(cuid())
  email        String         @unique
  passwordHash String
  name         String
  role         String         @default("CLIENT") // ADMIN, CLIENT
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  audits       AuditRequest[]
  projects     Project[]
  subscription Subscription?
}

model Project {
  id           String        @id @default(cuid())
  name         String
  description  String?
  status       String        @default("ACTIVE") // ACTIVE, COMPLETED, ON_HOLD
  userId       String
  user         User          @relation(fields: [userId], references: [id])
  deliverables Deliverable[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model Deliverable {
  id          String   @id @default(cuid())
  title       String
  description String?
  status      String   @default("TODO") // TODO, IN_PROGRESS, COMPLETED
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id])
  dueDate     DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Subscription {
  id               String   @id @default(cuid())
  userId           String   @unique
  user             User     @relation(fields: [userId], references: [id])
  plan             String   // STARTER, GROWTH, TRANSFORMATION
  status           String   @default("INACTIVE") // ACTIVE, INACTIVE, EXPIRED
  paystackRef      String?
  amount           Int
  nextBillingDate  DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model CustomChallenge {
  id        String   @id @default(cuid())
  label     String
  industry  String   // Which industry this was added for
  count     Int      @default(1) // How many times it's been suggested
  createdAt DateTime @default(now())

  @@unique([label, industry])
}
